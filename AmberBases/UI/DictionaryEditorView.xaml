<UserControl x:Class="AmberBases.UI.DictionaryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AmberBases.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dictionary selector tabs -->
        <TabControl x:Name="TablesTabControl" Grid.Row="0" SelectionChanged="TablesTabControl_SelectionChanged">
            <TabItem Header="Поставщики">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="SystemProvidersGrid"/></Grid>
            </TabItem>
            <TabItem Header="Системы профилей">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="ProfileSystemsGrid"/></Grid>
            </TabItem>
            <TabItem Header="Цвета">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="ColorsGrid"/></Grid>
            </TabItem>
            <TabItem Header="Хлыст">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="StandartBarLengthsGrid"/></Grid>
            </TabItem>
            <TabItem Header="Типы профилей">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="ProfileTypesGrid"/></Grid>
            </TabItem>
            <TabItem Header="Применимости">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="ApplicabilitiesGrid"/></Grid>
            </TabItem>
            <TabItem Header="Артикулы Профилей">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="ProfileArticlesGrid"/></Grid>
            </TabItem>
            <TabItem Header="Типы покрытий">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="CoatingTypesGrid"/></Grid>
            </TabItem>
            <TabItem Header="С-Proфили">
                <Grid Margin="5"><local:DictionaryTableControl x:Name="CProfilesGrid"/></Grid>
            </TabItem>
        </TabControl>

        <!-- Bottom Actions -->
        <Border Grid.Row="1" Background="#f0f0f0" Padding="5">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="UndoBtn" Content="Undo" Click="UndoBtn_Click" Margin="5" Padding="10,5" IsEnabled="False"/>
                <Button x:Name="RedoBtn" Content="Redo" Click="RedoBtn_Click" Margin="5" Padding="10,5" IsEnabled="False"/>
                <Separator Margin="5"/>
                <Button Content="Refresh Data" Click="BtnRefresh_Click" Margin="5" Padding="10,5"/>
                <Button Content="Save Changes" Click="BtnSave_Click" Margin="5" Padding="10,5"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>