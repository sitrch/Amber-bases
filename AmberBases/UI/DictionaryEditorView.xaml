<UserControl x:Class="AmberBases.UI.DictionaryEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AmberBases.UI"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="DictionarySelectorRow" Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dictionary selector -->
        <Border x:Name="DictionarySelectorBorder" Grid.Row="0" Background="#f0f0f0" Padding="5">
            <StackPanel Orientation="Horizontal">
                <Button Content="Поставщики" Click="BtnShowGrid_Click" Tag="SystemProvidersGrid" Margin="2" Padding="5,2"/>
                <Button Content="Системы профилей" Click="BtnShowGrid_Click" Tag="ProfileSystemsGrid" Margin="2" Padding="5,2"/>
                <Button Content="Цвета" Click="BtnShowGrid_Click" Tag="ColorsGrid" Margin="2" Padding="5,2"/>
                <Button Content="Хлыст" Click="BtnShowGrid_Click" Tag="StandartBarLengthsGrid" Margin="2" Padding="5,2"/>
                <Button Content="Типы профилей" Click="BtnShowGrid_Click" Tag="ProfileTypesGrid" Margin="2" Padding="5,2"/>
                <Button Content="Применимости" Click="BtnShowGrid_Click" Tag="ApplicabilitiesGrid" Margin="2" Padding="5,2"/>
                <Button Content="Артикулы Профилей" Click="BtnShowGrid_Click" Tag="ProfileArticlesGrid" Margin="2" Padding="5,2"/>
                <Button Content="Типы покрытий" Click="BtnShowGrid_Click" Tag="CoatingTypesGrid" Margin="2" Padding="5,2"/>
                <Button Content="С-Proфили" Click="BtnShowGrid_Click" Tag="CProfilesGrid" Margin="2" Padding="5,2"/>
            </StackPanel>
        </Border>

        

        <!-- Grids -->
        <Grid Grid.Row="2" Margin="5">
            <local:DictionaryTableControl x:Name="SystemProvidersGrid" Visibility="Visible"/>
            <local:DictionaryTableControl x:Name="ProfileSystemsGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="ColorsGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="StandartBarLengthsGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="ProfileTypesGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="ApplicabilitiesGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="ProfileArticlesGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="CoatingTypesGrid" Visibility="Collapsed"/>
            <local:DictionaryTableControl x:Name="CProfilesGrid" Visibility="Collapsed"/>
        </Grid>

        <!-- Bottom Actions -->
        <Border Grid.Row="3" Background="#f0f0f0" Padding="5">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="UndoBtn" Content="Undo" Click="UndoBtn_Click" Margin="5" Padding="10,5" IsEnabled="False"/>
                <Button x:Name="RedoBtn" Content="Redo" Click="RedoBtn_Click" Margin="5" Padding="10,5" IsEnabled="False"/>
                <Separator Margin="5"/>
                <Button Content="Refresh Data" Click="BtnRefresh_Click" Margin="5" Padding="10,5"/>
                <Button Content="Save Changes" Click="BtnSave_Click" Margin="5" Padding="10,5"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>