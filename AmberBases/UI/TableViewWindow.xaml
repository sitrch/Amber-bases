<Window x:Class="AmberBases.UI.TableViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:AmberBases.UI"
        Title="Таблица" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        MinHeight="300" MinWidth="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Table Control -->
        <ui:DictionaryTableControl x:Name="TableControl" Grid.Row="0"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Width="100" Margin="0,0,5,0" Click="BtnSave_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            <Button Content="Отменить" Width="100" Margin="0,0,5,0" Click="BtnCancel_Click" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            <Button Content="Закрыть" Width="100" Click="BtnClose_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>