<Window x:Class="AmberBases.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ribbon="clr-namespace:System.Windows.Controls.Ribbon;assembly=System.Windows.Controls.Ribbon"
        xmlns:ui="clr-namespace:AmberBases.UI"
        Title="Amber Bases" Height="600" Width="1000"
        Closing="MainWindow_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RibbonRow" Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ribbon Menu -->
        <ribbon:Ribbon x:Name="MainRibbon" Grid.Row="0" SelectionChanged="MainRibbon_SelectionChanged">
            <!-- Application Menu (File) -->
            <ribbon:Ribbon.ApplicationMenu>
                <ribbon:RibbonApplicationMenu SmallImageSource="{x:Null}">
                    <ribbon:RibbonApplicationMenuItem Header="Материалы" Click="MenuMaterials_Click"/>
                    <ribbon:RibbonApplicationMenuItem Header="Загрузчик Excel" Click="MenuExcelLoader_Click"/>
                    <ribbon:RibbonApplicationMenuItem Header="Справочники" Click="MenuDictionaries_Click"/>
                    <ribbon:RibbonSeparator />
                    <ribbon:RibbonApplicationMenuItem Header="Выход" Click="MenuExit_Click"/>
                </ribbon:RibbonApplicationMenu>
            </ribbon:Ribbon.ApplicationMenu>

            <!-- Materials Tab -->
            <ribbon:RibbonTab x:Name="MaterialsTab" Header="Материалы">
            <ribbon:RibbonGroup x:Name="MaterialsGroup" Header="Материалы">
                <ribbon:RibbonButton Label="Артикулы профилей" Click="BtnShowProfileArticles_Click"/>
            </ribbon:RibbonGroup>
            </ribbon:RibbonTab>

            <!-- Excel Tab -->
             <ribbon:RibbonTab x:Name="ExcelTab" Header="Загрузчик Excel">
                <ribbon:RibbonGroup x:Name="FileOperationsGroup" Header="File Operations">
                     <ribbon:RibbonButton Label="Обзор..." Click="BtnLoadExcel_Click" LargeImageSource="{x:Null}"/>
                     <ribbon:RibbonComboBox Label="Файл:" x:Name="cbFiles" Width="200" IsEditable="False">
                        <ribbon:RibbonGallery x:Name="galleryFiles" MaxColumnCount="1" SelectionChanged="CbFiles_SelectionChanged">
                            <ribbon:RibbonGalleryCategory x:Name="filesGalleryCategory" />
                        </ribbon:RibbonGallery>
                    </ribbon:RibbonComboBox>
                </ribbon:RibbonGroup>

                <ribbon:RibbonGroup x:Name="DatabaseOperationsGroup" Header="Database Operations">
                     <ribbon:RibbonComboBox Label="Таблица:" x:Name="cbTables" Width="150" IsEditable="False" IsEnabled="False">
                        <ribbon:RibbonGallery x:Name="galleryTables" MaxColumnCount="1" SelectionChanged="CbTables_SelectionChanged">
                            <ribbon:RibbonGalleryCategory x:Name="tablesGalleryCategory" />
                        </ribbon:RibbonGallery>
                    </ribbon:RibbonComboBox>
                     <ribbon:RibbonButton Label="Сохранить в SQLite" x:Name="btnSaveSqlite" Click="BtnSaveSqlite_Click" IsEnabled="False" LargeImageSource="{x:Null}"/>
                </ribbon:RibbonGroup>
            </ribbon:RibbonTab>

            <!-- Dictionaries Tab -->
             <ribbon:RibbonTab x:Name="DictionariesTab" Header="Справочники">
                  <ribbon:RibbonGroup x:Name="DictionariesViewGroup" Header="Просмотр">
                     <ribbon:RibbonButton Label="Показать справочники" Click="BtnShowDictionaries_Click"/>
                 </ribbon:RibbonGroup>
            </ribbon:RibbonTab>
        </ribbon:Ribbon>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <!-- Excel Loader View -->
            <Grid x:Name="ExcelView" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="dataGrid" AutoGenerateColumns="True" IsReadOnly="True" 
                          SelectionMode="Extended" SelectionUnit="CellOrRowHeader" Grid.Row="0" Margin="5"/>
                <StatusBar Grid.Row="1">
                    <StatusBarItem>
                        <TextBlock x:Name="lblStatus" Text="Ready"/>
                    </StatusBarItem>
                </StatusBar>
            </Grid>

            <!-- Dictionaries View -->
            <ui:DictionaryEditorView x:Name="DictionaryEditor" Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>